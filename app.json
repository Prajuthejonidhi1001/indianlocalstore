{
  "expo": {
    "name": "IndianLocalStore",
    "slug": "indianlocalstore",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "indianlocalstore",
    "description": "Your Trusted Neighbourhood Marketplace - Discover local shops, fresh products & support local businesses",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050814"
    },
    "icon": "./assets/icon.png",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location"
        }
      ]
    ],
    "android": {
      "package": "com.indianlocalstore.app",
      "versionCode": 2,
      "minSdkVersion": 24,
      "targetSdkVersion": 34,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-icon-bg.png",
        "backgroundColor": "#0D1B5E"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.indianlocalstore.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to upload product photos",
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show nearby shops",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload product images",
        "NSPhotoLibraryAddOnlyUsageDescription": "This app needs to save photos to your library",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7c3ee6ec-0ebd-442a-abfc-c49480f26988"
      }
    },
    "owner": "prajwalthejonidhi"
  }
}
